## ---- LLM ----
LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_API_MODE=
# OPENAI_REASONING_EFFORT=medium

## ---- Agent ----
AGENT_MAX_STEPS=25
AGENT_CONTEXT_TAIL=30
AGENT_MEMORY_HITS=5
AGENT_DEDUP_DISTANCE=0.08
AGENT_VECTOR_COLLECTION=memories

## ---- Skills ----
SKILL_HTTP_TIMEOUT=30
SKILL_SHELL_ENABLED=false
SKILL_SSH_ENABLED=false
# SKILL_SSH_DEFAULT_USER=ubuntu
# SKILL_SSH_IDENTITY_FILE=/app/data/id_rsa
# SKILL_SSH_PRIVATE_KEY=

## ---- Telegram bot ----
TELEGRAM_BOT_TOKEN=
BOT_AUTH_ENABLED=false
BOT_ADMIN_ID=0

## ---- Network ----
BACKEND_PORT=8000

## ---- Docker bind-mount permissions ----
# Containers run as this UID:GID so ./data files are owned by the host user.
# `make` targets export these automatically from `id -u` / `id -g`.
# Set here only if running docker compose directly without make.
# UID=1000
# GID=1000
